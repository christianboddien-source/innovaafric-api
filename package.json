{
  "name": "innovaafric-api",
  "version": "1.0.0",
  "description": "INNOVAAFRIC REST API — Ecosistema digital tricontinental",
  "main": "server.js",
  "scripts": {
    "start": "node node_modules/prisma/build/index.js migrate deploy && node server.js",
    "postinstall": "node node_modules/prisma/build/index.js generate",
    "dev": "nodemon server.js",
    "test": "jest --coverage --runInBand --forceExit",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "node node_modules/prisma/build/index.js studio",
    "db:reset": "node node_modules/prisma/build/index.js migrate reset --force && node prisma/seed.js",
    "db:generate": "node node_modules/prisma/build/index.js generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "UNLICENSED",
  "author": "INNOVAAFRIC Tech Team",
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/globalSetup.js",
    "setupFiles": ["./tests/setEnv.js"],
    "setupFilesAfterFramework": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"],
    "testTimeout": 30000
  }
}
