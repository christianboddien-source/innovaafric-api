PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────
# Min 32 chars random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars_change_this

# ── CORS ─────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
ALLOWED_ORIGINS=https://christianboddien-source.github.io,https://www.xendermoney.com,https://www.xendershop.com,https://www.xenderdelivery.com,https://www.xenderbigshop.com

# ── PostgreSQL (Railway auto-injects DATABASE_URL) ────────
# Railway provides this automatically — do NOT change it in Railway dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── Supabase (for webhook sync) ───────────────────────────
SUPABASE_URL=https://spnfvmvrlexyiljwyola.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_your_service_key_here

# ── Webhook secret (Supabase → Railway sync) ─────────────
# Must match the X-Webhook-Secret header sent by Supabase trigger
WEBHOOK_SECRET=innovaafric_sync_2026

# ── Stripe (optional — payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMS / Twilio (optional) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM=+1234567890

# ── Email / SendGrid (optional) ──────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxx
EMAIL_FROM=no-reply@innovaafric.com

# ── Rate limits ───────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
