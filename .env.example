PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/innovaafric"

# Separate test database (required for npm test)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/innovaafric_test"

# Production example (Railway / Supabase / Neon / Render)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
