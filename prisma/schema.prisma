datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Roles ─────────────────────────────────────────────────────
enum UserRole {
  customer
  rider
  supplier
  circular_autorizada
  api_partner
  city_coordinator
  rider_coordinator
  business_developer
  kyc_officer
  loan_officer
  support_agent
  marketing_manager
  tax_officer
  payroll_manager
  support_supervisor
  compliance_officer
  finance_officer
  risk_officer
  auditor
  country_manager
  regional_director
  super_admin
  admin
}

model User {
  id                String   @id
  email             String   @unique
  name              String
  phone             String
  country           String
  role              UserRole @default(customer)
  passwordHash      String
  kycStatus         String   @default("pending")
  // 2FA
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  // Comisiones representante
  representativeId  String?
  commissionRate    Float    @default(0)
  kycDocument   String?
  referralCode  String?
  blocked       Boolean  @default(false)
  blockedReason String?
  scope         String?
  city          String?
  department    String?
  createdAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet          Wallet?
  sentTxns        Transaction[]       @relation("SentTxns")
  receivedTxns    Transaction[]       @relation("ReceivedTxns")
  orders          Order[]
  groceryOrders   GroceryOrder[]
  billPayments    BillPayment[]
  tontineMembers  TontineMember[]
  virtualCards    VirtualCard[]
  notifications   Notification[]
  loyalty         LoyaltyAccount?
  business        BusinessAccount?
  wishlist        WishlistItem[]
  reviews         Review[]
  referrerOf      Referral[]          @relation("Referrer")
  referredBy      Referral?           @relation("Referred")
  bulkPayments    BulkPayment[]
  invoicesIssued  Invoice[]           @relation("Issuer")
  invoicesPaid    Invoice[]           @relation("Payer")
  cartItems       CartItem[]
  bankAccounts    UserBankAccount[]
  loans           Loan[]
  chatMessages    ChatMessage[]       @relation("ChatSent")
  bankTransfers   BankTransfer[]
  creditScore     CreditScore?
  installments    Installment[]
  savingsGoals    SavingsGoal[]
  fundInvestments FundInvestment[]
}

model Wallet {
  id         String @id @default(cuid())
  userId     String @unique
  balanceEur Float  @default(0)
  balanceUsd Float  @default(0)
  balanceXaf Float  @default(0)
  balanceXof Float  @default(0)
  user       User   @relation(fields: [userId], references: [id])
}

model Transaction {
  id               String   @id
  type             String
  userId           String
  recipientId      String?
  amountSent       Float?
  currencySent     String?
  amountReceived   Float?
  currencyReceived String?
  fee              Float    @default(0)
  exchangeRate     Float?
  amount           Float?
  currency         String?
  method           String?
  destination      String?
  reference        String?
  note             String?
  merchantId       String?
  status           String   @default("completed")
  createdAt        DateTime @default(now())

  user      User  @relation("SentTxns",     fields: [userId],      references: [id])
  recipient User? @relation("ReceivedTxns", fields: [recipientId], references: [id])
}

model Product {
  id           String  @id
  name         String
  description  String?
  priceEur     Float
  priceXaf     Float
  category     String
  stock        Int     @default(0)
  origin       String?
  imageUrl     String?
  ceCertified  Boolean @default(true)
  deliveryDays Int     @default(5)
  ratingAvg    Float?
  ratingCount  Int     @default(0)

  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
}

model GroceryProduct {
  id        String  @id
  name      String
  priceXaf  Float
  category  String
  store     String
  available Boolean @default(true)

  groceryOrderItems GroceryOrderItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  priceEur  Float
  priceXaf  Float

  user    User    @relation(fields: [userId],    references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id                  String    @id
  userId              String
  totalEur            Float
  totalXaf            Float
  paymentCurrency     String
  paymentAmount       Float
  deliveryAddress     String
  notes               String?
  status              String    @default("confirmed")
  estimatedDelivery   String?
  trackingId          String    @unique
  hubLocation         String?
  loyaltyPointsEarned Int       @default(0)
  deliveryProof       String?
  createdAt           DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  priceEur  Float
  priceXaf  Float

  order   Order   @relation(fields: [orderId],   references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model GroceryOrder {
  id                String    @id
  userId            String
  totalXaf          Float
  notes             String?
  deliveryAddress   String
  riderId           String?
  status            String    @default("preparing")
  estimatedDelivery String?
  deliveryProof     String?
  // Rider fee
  riderFeeXaf       Float     @default(0)
  riderFeeStatus    String    @default("pending")  // pending|escrow|released|manual_released
  riderPaymentMode  String    @default("auto")     // auto|manual
  confirmedAt       DateTime?
  riderPaidAt       DateTime?
  createdAt         DateTime  @default(now())

  user  User               @relation(fields: [userId],  references: [id])
  rider Rider?             @relation(fields: [riderId], references: [id])
  items GroceryOrderItem[]
}

model GroceryOrderItem {
  id             String @id @default(cuid())
  groceryOrderId String
  productId      String
  quantity       Int
  priceXaf       Float

  groceryOrder GroceryOrder   @relation(fields: [groceryOrderId], references: [id])
  product      GroceryProduct @relation(fields: [productId],      references: [id])
}

model Rider {
  id              String   @id
  name            String
  phone           String
  zone            String
  vehicle         String
  status          String   @default("available")
  rating          Float?
  deliveriesTotal Int      @default(0)
  registeredBy    String?
  userId          String?  @unique   // enlace a User (wallet XenderMoney)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  groceryOrders GroceryOrder[]
}

model PayrollRun {
  id          String        @id @default(cuid())
  period      String
  totalAmount Float         @default(0)
  currency    String        @default("XAF")
  status      String        @default("draft")
  notes       String?
  createdBy   String
  executedAt  DateTime?
  createdAt   DateTime      @default(now())
  items       PayrollItem[]
}

model PayrollItem {
  id          String     @id @default(cuid())
  payrollId   String
  riderId     String
  riderName   String
  deliveries  Int        @default(0)
  ratePerDelivery Float  @default(0)
  amount      Float      @default(0)
  status      String     @default("pending")
  payroll     PayrollRun @relation(fields: [payrollId], references: [id])
}

model Merchant {
  id         String  @id
  name       String
  circularId String
  qrCode     String  @unique
  active     Boolean @default(true)
}

model ApiClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientSecret String
  name         String
  scopes       String
  active       Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
}

model BillProvider {
  id        String @id
  name      String
  category  String
  country   String
  field     String
  currency  String @default("XAF")
  minAmount Float
  maxAmount Float

  payments BillPayment[]
}

model BillPayment {
  id               String   @id
  userId           String
  providerId       String
  amount           Float
  currency         String
  referenceNumber  String
  note             String?
  status           String   @default("completed")
  confirmationCode String
  createdAt        DateTime @default(now())

  user     User         @relation(fields: [userId],     references: [id])
  provider BillProvider @relation(fields: [providerId], references: [id])
}

model Tontine {
  id                 String   @id
  name               String
  description        String?
  adminId            String
  contributionAmount Float
  currency           String   @default("XAF")
  frequency          String
  maxMembers         Int
  currentRound       Int      @default(1)
  status             String   @default("open")
  createdAt          DateTime @default(now())

  members       TontineMember[]
  contributions TontineContribution[]
}

model TontineMember {
  id          String   @id @default(cuid())
  tontineId   String
  userId      String
  turn        Int
  hasReceived Boolean  @default(false)
  joinedAt    DateTime @default(now())

  tontine Tontine @relation(fields: [tontineId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])

  @@unique([tontineId, userId])
}

model TontineContribution {
  id        String   @id
  tontineId String
  userId    String
  round     Int
  amount    Float
  currency  String
  createdAt DateTime @default(now())

  tontine Tontine @relation(fields: [tontineId], references: [id])
}

model VirtualCard {
  id          String    @id
  userId      String
  label       String
  number      String
  cvv         String
  expiry      String
  currency    String
  balance     Float     @default(0)
  status      String    @default("active")
  frozen      Boolean   @default(false)
  spentTotal  Float     @default(0)
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())

  user         User                   @relation(fields: [userId], references: [id])
  transactions VirtualCardTransaction[]
}

model VirtualCardTransaction {
  id        String   @id @default(cuid())
  cardId    String
  type      String
  amount    Float
  createdAt DateTime @default(now())

  card VirtualCard @relation(fields: [cardId], references: [id])
}

model Review {
  id         String   @id
  type       String
  targetId   String
  targetName String
  userId     String
  rating     Int
  comment    String?
  orderId    String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([type, targetId, userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Coupon {
  id            String   @id
  code          String   @unique
  discountType  String
  discountValue Float
  minOrderEur   Float?
  minOrderXaf   Float?
  maxUses       Int
  uses          Int      @default(0)
  active        Boolean  @default(true)
  expiresAt     DateTime
  description   String?
  createdAt     DateTime @default(now())
}

model LoyaltyAccount {
  id            String         @id @default(cuid())
  userId        String         @unique
  points        Int            @default(0)
  totalEarned   Int            @default(0)
  totalRedeemed Int            @default(0)
  user          User           @relation(fields: [userId], references: [id])
  history       LoyaltyHistory[]
}

model LoyaltyHistory {
  id           String         @id @default(cuid())
  loyaltyId    String
  userId       String
  points       Int
  type         String
  source       String
  refId        String?
  balanceAfter Int
  createdAt    DateTime       @default(now())

  loyalty LoyaltyAccount @relation(fields: [loyaltyId], references: [id])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  bonusAwarded Int
  createdAt    DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])
}

model BusinessAccount {
  id            String   @id
  ownerId       String   @unique
  companyName   String
  taxId         String
  industry      String
  country       String
  address       String?
  website       String?
  status           String   @default("active")
  plan             String   @default("basic")
  monthlyLimitEur  Float    @default(10000)
  createdAt        DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner        User          @relation(fields: [ownerId],     references: [id])
  bulkPayments BulkPayment[]
  invoices     Invoice[]     @relation("BusinessInvoices")
}

model BulkPayment {
  id              String   @id
  ownerId         String
  businessId      String?
  companyName     String
  description     String?
  currency        String
  totalAmount     Float
  recipientsTotal Int
  succeeded       Int
  failed          Int
  status          String
  createdAt       DateTime @default(now())

  owner    User             @relation(fields: [ownerId],     references: [id])
  business BusinessAccount? @relation(fields: [businessId], references: [id])
  results  BulkPaymentResult[]
}

model BulkPaymentResult {
  id            String  @id @default(cuid())
  bulkPaymentId String
  recipientRef  String
  recipientName String?
  amount        Float?
  status        String
  reason        String?

  bulkPayment BulkPayment @relation(fields: [bulkPaymentId], references: [id])
}

model Invoice {
  id              String    @id
  invoiceNumber   String    @unique
  issuerId        String
  issuerName      String
  businessId      String?
  clientId        String?
  clientName      String
  clientEmail     String?
  currency        String
  subtotal        Float
  taxRate         Float
  taxAmount       Float
  totalEur        Float
  notes           String?
  status          String    @default("draft")
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  paidBy          String?
  // Rider delivery fee embedded in invoice
  riderFeeXaf     Float     @default(0)
  deliveryOrderId String?   @unique
  createdAt       DateTime  @default(now())

  issuer   User             @relation("Issuer", fields: [issuerId], references: [id])
  payer    User?            @relation("Payer",  fields: [paidBy],   references: [id])
  business BusinessAccount? @relation("BusinessInvoices", fields: [businessId], references: [id])
  items    InvoiceItem[]
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  subtotal    Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String    @default("info")
  channel   String    @default("in_app")
  data      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Webhook {
  id        String   @id @default(cuid())
  event     String
  data      String
  timestamp DateTime @default(now())
}

model ExchangeRate {
  id        String   @id @default(cuid())
  pair      String   @unique
  rate      Float
  updatedAt DateTime @updatedAt
}

model ProviderCategory {
  id          String   @id
  name        String
  slug        String   @unique
  icon        String?
  color       String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Tax {
  id          String   @id
  name        String
  type        String
  rate        Float
  country     String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Bank {
  id          String   @id
  name        String
  code        String?
  country     String
  currency    String
  swiftCode   String?
  ibanFormat  String?
  logo        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  userAccounts UserBankAccount[]
}

model UserBankAccount {
  id            String   @id
  userId        String
  bankId        String
  accountNumber String
  accountName   String
  iban          String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  bank Bank @relation(fields: [bankId], references: [id])
}

model Loan {
  id           String    @id
  userId       String
  amount       Float
  currency     String    @default("XAF")
  purpose      String
  status       String    @default("pending")
  interestRate Float     @default(5)
  repaidAmount Float     @default(0)
  dueDate      DateTime?
  approvedBy   String?
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id
  fromId    String
  toId      String?
  room      String   @default("support")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  from User @relation("ChatSent", fields: [fromId], references: [id])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("announcement")
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(true)
  country     String?
  city        String?
  color       String    @default("#00AEEF")
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BankTransfer {
  id            String    @id @default(cuid())
  userId        String
  amount        Float
  currency      String    @default("XAF")
  bankName      String
  accountName   String
  accountNumber String
  swiftCode     String?
  ibanCode      String?
  country       String
  reference     String?
  status        String    @default("pending")
  notes         String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailLog {
  id         String   @id @default(cuid())
  toFilter   String
  subject    String
  body       String
  type       String   @default("info")
  sentBy     String
  recipients Int      @default(0)
  status     String   @default("sent")
  createdAt  DateTime @default(now())
}

model Campaign {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("promo")
  status      String    @default("draft")
  target      String    @default("all")
  discount    Float?
  code        String?   @unique
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SupportTicket {
  id           String    @id @default(cuid())
  userId       String?
  name         String
  email        String
  subject      String
  message      String
  status       String    @default("open")
  priority     String    @default("medium")
  category     String    @default("general")
  response     String?
  respondedAt  DateTime?
  respondedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CountryConfig {
  id             String   @id
  country        String   @unique
  name           String
  active         Boolean  @default(true)
  p2pEnabled     Boolean  @default(true)
  loansEnabled   Boolean  @default(true)
  groceryEnabled Boolean  @default(true)
  cardsEnabled   Boolean  @default(true)
  repName        String?
  repEmail       String?
  repPhone       String?
  updatedAt      DateTime @updatedAt
}

model ApiKey {
  id          String   @id @default(cuid())
  partnerName String
  keyPrefix   String
  fullKey     String   @unique
  environment String   @default("test")
  permissions String   @default("read")
  rateLimit   Int      @default(1000)
  callCount   Int      @default(0)
  status      String   @default("activa")
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ── Partners (socios de negocio) ──────────────────────────────
model Partner {
  id         String   @id @default(cuid())
  name       String
  type       String   // fintech, ecommerce, telecom, bank...
  country    String
  contact    String?
  phone      String?
  share      Float    @default(2.5)   // % comisión
  status     String   @default("activo")
  joinedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invoices PartnerInvoice[]
}

model PartnerInvoice {
  id        String   @id @default(cuid())
  partnerId String
  amount    Float
  currency  String   @default("XAF")
  period    String
  dueDate   DateTime
  status    String   @default("pendiente")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id])
}

// ── Credit scores ─────────────────────────────────────────────
model CreditScore {
  id           String   @id @default(cuid())
  userId       String   @unique
  score        Int      @default(500)
  rating       String   @default("C")
  historyMonths Int     @default(0)
  onTimePayments Int    @default(0)
  defaults     Int      @default(0)
  txCount      Int      @default(0)
  approved     Boolean  @default(false)
  notes        String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── Installments (compras a plazos) ──────────────────────────
model Installment {
  id          String    @id @default(cuid())
  userId      String
  productName String
  total       Float
  currency    String    @default("XAF")
  paid        Float     @default(0)
  months      Int
  monthlyFee  Float
  nextDueDate DateTime?
  status      String    @default("activo")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── Insurance ─────────────────────────────────────────────────
model InsurancePlan {
  id          String   @id @default(cuid())
  name        String
  type        String   // vida, salud, agricola, vehiculo...
  coverage    Float
  premium     Float
  currency    String   @default("XAF")
  duration    Int      // meses
  provider    String
  status      String   @default("activo")
  subscribers Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claims InsuranceClaim[]
}

model InsuranceClaim {
  id          String   @id @default(cuid())
  planId      String
  userId      String?
  userEmail   String
  amount      Float
  currency    String   @default("XAF")
  description String
  status      String   @default("pendiente")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan InsurancePlan @relation(fields: [planId], references: [id])
}

// ── Investment funds ──────────────────────────────────────────
model InvestmentFund {
  id          String   @id @default(cuid())
  name        String
  category    String
  target      Float
  raised      Float    @default(0)
  currency    String   @default("XAF")
  minInvest   Float    @default(25000)
  returnRate  Float    @default(8.0)
  durationMonths Int   @default(24)
  status      String   @default("activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investments FundInvestment[]
}

model FundInvestment {
  id       String   @id @default(cuid())
  fundId   String
  userId   String
  amount   Float
  currency String   @default("XAF")
  status   String   @default("activo")
  createdAt DateTime @default(now())

  fund InvestmentFund @relation(fields: [fundId], references: [id])
  user User           @relation(fields: [userId],  references: [id])
}

// ── Savings goals ─────────────────────────────────────────────
model SavingsGoal {
  id          String    @id @default(cuid())
  userId      String
  name        String
  target      Float
  current     Float     @default(0)
  currency    String    @default("XAF")
  deadline    DateTime?
  autoSave    Float     @default(0)
  status      String    @default("activo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── White-label instances ─────────────────────────────────────
model WhiteLabelInstance {
  id         String   @id @default(cuid())
  name       String
  partnerId  String?
  domain     String   @unique
  colorPrimary String @default("#00AEEF")
  status     String   @default("activo")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Refund requests ───────────────────────────────────────────
model RefundRequest {
  id          String   @id @default(cuid())
  orderId     String?
  userId      String?
  userEmail   String
  merchantName String?
  amount      Float
  currency    String   @default("XAF")
  reason      String
  status      String   @default("pendiente")
  notes       String?
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Merchant profiles (extended info for admin) ───────────────
model MerchantProfile {
  id        String   @id @default(cuid())
  name      String
  category  String
  country   String
  city      String?
  contact   String?
  phone     String?
  currency  String   @default("XAF")
  status    String   @default("activo")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhysicalCard {
  id          String    @id @default(cuid())
  userId      String?
  userName    String
  userEmail   String
  country     String
  network     String    @default("Visa")
  last4       String?
  status      String    @default("pendiente")
  limitAmount Float     @default(100000)
  currency    String    @default("XAF")
  notes       String?
  requestedAt DateTime  @default(now())
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Configuración de comisiones (configurable por admin) ─────
model CommissionConfig {
  id          String   @id @default(cuid())
  country     String   @default("*")      // * = global, ES, CM, SN...
  feeType     String                       // transfer|withdrawal|maintenance|delivery|p2p
  totalRate   Float                        // % total cobrado al cliente (ej: 0.02 = 2%)
  ivaRate     Float    @default(0.19)      // % de IVA que va a Hacienda (sobre el fee bruto)
  repRate     Float    @default(0)         // % que va al representante (sobre el fee neto)
  active      Boolean  @default(true)
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([country, feeType])
}

// ── Registro de distribución de comisiones (audit trail) ─────
model CommissionRecord {
  id             String   @id @default(cuid())
  transactionId  String?
  orderId        String?
  invoiceId      String?
  feeType        String
  currency       String   @default("EUR")
  grossFee       Float                    // fee total cobrado
  ivaAmount      Float    @default(0)     // porción para Hacienda
  innovaAmount   Float                    // porción neta para InnovaAFRIC
  repAmount      Float    @default(0)     // porción para representante
  repId          String?                  // userId del representante
  repName        String?
  status         String   @default("distributed") // distributed|pending|reversed
  createdAt      DateTime @default(now())
}

// ── Representantes (red comercial) ──────────────────────────
model Representative {
  id             String   @id @default(cuid())
  userId         String   @unique          // enlace al User (rol: business_developer, etc.)
  zone           String                    // ciudad o país que cubre
  country        String
  commissionRate Float    @default(0.005)  // 0.5% por defecto
  status         String   @default("active")
  totalEarned    Float    @default(0)
  clientCount    Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AccountingEntry {
  id          String   @id
  type        String
  category    String
  amount      Float
  currency    String   @default("XAF")
  description String
  reference   String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}
